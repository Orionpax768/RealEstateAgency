<Window x:Class="RealEstateAgency.AddObjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RealEstateAgency"
        mc:Ignorable="d"
        Title="Добавление объекта недвижимости" Height="450" Width="800" Icon="/free-icon-office-5380554.png">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black" Offset="1"/>
                <GradientStop Color="#FF20E9ED" Offset="0"/>
            </LinearGradientBrush>
        </Grid.Background>
        <StackPanel Margin="30,20,30,20" VerticalAlignment="Center">
            <TextBlock Text="Новый объект" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            <TextBlock Text="Название / Тип (например, 2-к. квартира)*" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtObjTitle" Height="28" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="Цена (млн ₽)*" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtObjPrice" Height="28" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,0,12"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Площадь (м²)*" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtObjArea" Height="28" FontSize="14" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Этаж / Этажность*" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtObjFloor" Height="28" FontSize="14" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="Адрес (Район, улица, дом)*" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtObjAddress" Height="28" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="Статус объекта*" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cbObjStatus" Height="28" FontSize="14" VerticalContentAlignment="Center" SelectedIndex="0" Margin="0,0,0,20">
                <ComboBoxItem Content="Свободно"/>
                <ComboBoxItem Content="Забронировано"/>
                <ComboBoxItem Content="Продано / Аренда"/>
            </ComboBox>
            <UniformGrid Columns="2" Height="35">
                <Button x:Name="btnSaveObject" Content="Добавить" Margin="0,0,5,0" FontSize="14" FontWeight="Bold" Click="btnSaveObject_Click"/>
                <Button x:Name="btnCancelAdd" Content="Отмена" Margin="5,0,0,0" FontSize="14" FontWeight="Bold" Click="btnCancelAdd_Click"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
