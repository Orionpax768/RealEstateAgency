<Window x:Class="RealEstateAgency.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RealEstateAgency"
        mc:Ignorable="d"
        Title="LoginWindow" Height="450" Width="800" Icon="/free-icon-office-5380554.png">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black" Offset="1"/>
                <GradientStop Color="#FF20E9ED" Offset="0"/>
            </LinearGradientBrush>
        </Grid.Background>
        <StackPanel VerticalAlignment="Top" Margin="166,101,166,0" Height="265">
            <TextBlock Text="Вход в систему" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Email/Number*" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="19*"/>
                    <ColumnDefinition Width="378*"/>
                    <ColumnDefinition Width="110*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtLogin" Height="25" Grid.ColumnSpan="2"/>
                <ComboBox x:Name="cmbDomainsLog" Grid.Column="2" Height="25" SelectedIndex="0">
                    <ComboBoxItem Content="@gmail.com"/>
                    <ComboBoxItem Content="@mail.ru"/>
                    <ComboBoxItem Content="@yandex.ru"/>
                </ComboBox>
            </Grid>
            <TextBlock Text="Пароль*" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="passLogin" Height="25" Margin="0,0,0,5"/>
            <Button x:Name="btnForgotPassword" Content="Забыли пароль?" Background="Transparent" Foreground="#64B5F6" BorderThickness="0" HorizontalAlignment="Right" Margin="0,0,0,25"/>
            <UniformGrid Columns="2" Rows="1" Height="35">
                <Button x:Name="btnLogin" Content="Войти" Margin="0,0,5,0" Background="Transparent" BorderBrush="White" Foreground="White" Click="btnLogin_Click"/>
                <Button x:Name="btnRegister" Content="Регистрация" Margin="5,0,0,0" Click="btnRegister_Click" Background="Transparent" BorderBrush="White" Foreground="White"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>