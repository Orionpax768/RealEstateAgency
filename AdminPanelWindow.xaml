<Window x:Class="RealEstateAgency.AdminPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RealEstateAgency"
        mc:Ignorable="d"
        Title="AdminPanelWindow" Height="450" Width="800" Icon="/free-icon-office-5380554.png">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black" Offset="1"/>
                <GradientStop Color="#FF20E9ED" Offset="0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel Margin="30,10,30,28">
            <TextBlock Text="Панель Администратора" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <DataGrid x:Name="dgRequests" AutoGenerateColumns="False" FontWeight="Bold" Height="260" Background="#0B5351" RowBackground="#0B5351" Foreground="#FF040404" FontSize="14">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Email (Логин)" Binding="{Binding Key}" Width="*"/>
                    <DataGridTextColumn Header="ФИО сотрудника" Binding="{Binding Value}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <UniformGrid Columns="4" Height="40" Margin="0,20,0,0">
                <Button x:Name="btnApprove" Content="Одобрить заявку" Margin="0,0,5,0" Background="Transparent" BorderBrush="White" Foreground="White" FontSize="12" FontWeight="Bold" Click="btnApprove_Click"/>
                <Button x:Name="btnReject" Content="Отклонить" Margin="5,0,5,0" Background="Transparent" BorderBrush="White" Foreground="White" FontSize="12" FontWeight="Bold" Click="btnReject_Click"/>
                <Button x:Name="btnGoToCatalog" Content="Каталог объектов" Margin="5,0,5,0" Background="Transparent" BorderBrush="White" Foreground="White" FontSize="11" FontWeight="Bold" Click="btnGoToCatalog_Click"/>
                <Button x:Name="btnExit" Content="Закрыть" Margin="5,0,0,0" Background="Transparent" BorderBrush="White" Foreground="White" FontSize="12" FontWeight="Bold" Click="btnExit_Click"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>