<Window x:Class="RealEstateAgency.CatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RealEstateAgency"
        mc:Ignorable="d"
        Title="CatalogWindow" Height="450" Width="800">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black" Offset="1"/>
                <GradientStop Color="#FF20E9ED" Offset="0"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtSearch" Height="30" FontSize="14" VerticalContentAlignment="Center" Grid.Column="0"/>
                    <Button x:Name="btnSearch" Content="Поиск" Grid.Column="1" Height="30" Margin="5,0,0,0" FontWeight="Bold"/>
                </Grid>
                <WrapPanel>
                    <Button x:Name="tagFlats" Content="[Квартиры]" Margin="0,0,5,0" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Click="tagFilter_Click"/>
                    <Button x:Name="tagHouses" Content="[Дома]" Margin="5,0,5,0" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Click="tagFilter_Click"/>
                    <Button x:Name="tagStudios" Content="[Студии]" Margin="5,0,5,0" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Click="tagFilter_Click"/>
                    <Button x:Name="tagPrice" Content="[До 10 млн ₽]" Margin="5,0,0,0" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" Click="tagFilter_Click"/>
                </WrapPanel>
            </StackPanel>
            <DataGrid x:Name="dgCatalog" Grid.Row="1" AutoGenerateColumns="False" Background="#0B5351" RowBackground="#0B5351" Foreground="White" FontSize="14" Margin="-10,0,10,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Тип объекта" Binding="{Binding Title}" Width="1.5*"/>
                    <DataGridTextColumn Header="Цена (млн ₽)" Binding="{Binding Price}" Width="*"/>
                    <DataGridTextColumn Header="Площадь" Binding="{Binding Area}" Width="*"/>
                    <DataGridTextColumn Header="Этаж" Binding="{Binding Floor}" Width="0.8*"/>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="2*"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="1.2*"/>
                </DataGrid.Columns>
            </DataGrid>
            <Grid Grid.Row="2" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="btnAddObjOpen" Content="Добавить новый объект" Height="35" Width="180" Margin="0,0,10,0" FontWeight="Bold" Click="btnAddObjOpen_Click"/>
                    <Button x:Name="btnChangeStatus" Content="Изменить статус" Height="35" Width="140" FontWeight="Bold" Click="btnChangeStatus_Click"/>
                </StackPanel>
                <Button x:Name="btnBackToMain" Content="Выйти из каталога" Grid.Column="2" Height="35" Width="150" FontWeight="Bold" Click="btnBackToMain_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>