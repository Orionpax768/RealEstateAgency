<Window x:Class="RealEstateAgency.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RealEstateAgency"
        mc:Ignorable="d"
        Title="RealEstateAgency — Главная" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FF1BB2B5" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Width="734" Height="269" RenderTransformOrigin="0.499,0.649" Margin="0,99,0,0">
            <TextBlock Text="Информационная Система" 
                       FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,5" Foreground="#FFFFE6E6"/>

            <TextBlock Text="Риелторское Агентство" 
                       FontSize="24" FontWeight="Bold" Foreground="#2B579A" 
                       HorizontalAlignment="Center" Margin="0,0,0,35"/>
            <Label x:Name="lblRegistr" 
                   Content="Вы уже зарегистрированы?" 
                   FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="White"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnOpenLogin" 
                        Content="Войти" 
                        Width="140" Height="40" Margin="0,0,20,0" 
                        Background="#2B579A" Foreground="White" FontSize="14" FontWeight="Bold"
                        Click="btnOpenLogin_Click"/>
                <Button x:Name="btnOpenRegister" 
                        Content="Зарегистрироваться" 
                        Width="180" Height="40" FontSize="14" FontWeight="Bold"
                        Click="btnOpenRegister_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
