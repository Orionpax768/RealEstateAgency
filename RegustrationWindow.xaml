<Window x:Class="RealEstateAgency.RegustrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RealEstateAgency"
        mc:Ignorable="d"
        Title="RegustrationWindow" Height="450" Width="800" Icon="/free-icon-office-5380554.png">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black" Offset="1"/>
                <GradientStop Color="#FF20E9ED" Offset="0"/>
            </LinearGradientBrush>
        </Grid.Background>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" Height="390">
            <TextBlock Text="Регистрация" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="ФИО*" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtBxFullname" Height="30" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,0,15"/>
            <TextBlock Text="Email/Number*" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtBxEmail" Height="30" FontSize="14" VerticalContentAlignment="Center" Grid.Column="0"/>
                <ComboBox x:Name="cmbDomains" Height="30" FontSize="14" VerticalContentAlignment="Center" Grid.Column="1" SelectedIndex="0">
                    <ComboBoxItem Content="@gmail.com"/>
                    <ComboBoxItem Content="@mail.ru"/>
                    <ComboBoxItem Content="@yandex.ru"/>
                </ComboBox>
            </Grid>
            <TextBlock Text="Пароль*" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtBxPassword" Height="30" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,0,15"/>
            <TextBlock Text="Подтверждение*" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtBxPassword2" Height="30" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,0,25"/>
            <UniformGrid Columns="2" Rows="1" Height="35">
                <Button x:Name="btnRegistration" Content="Зарегистрироваться" HorizontalAlignment="Left" Padding="15,5" FontSize="16" Foreground="White" Background="Transparent" BorderBrush="White" Click="btnRegistration_Click"/>
                <Button x:Name="btnLoginback" Content="Закрыть" BorderBrush="White" Foreground="White" Click="btnLoginback_Click">
                    <Button.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="Black" Offset="1"/>
                            <GradientStop Color="Transparent" Offset="0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>